# Copy this file to .env and fill in values before running
# .env is gitignored — never commit it

# Comma-separated list of allowed origins for CORS
# Example: https://jpas.askrindo-syariah.co.id,https://internal.example.com
ALLOWED_ORIGINS=http://localhost:8501

# Optional: simple bearer token for beta access control
# If set, the IT team's reverse proxy / auth layer should validate this token.
# Leave blank to disable token auth (rely on network-level access control instead).
JPAS_ACCESS_TOKEN=
